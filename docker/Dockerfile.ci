# Lightweight CI image — no ROS, just Python + tests
FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential gcc && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /workspace
COPY . .

RUN pip install --no-cache-dir -e ".[dev]" && \
    pip install --no-cache-dir hypothesis pytest-timeout

CMD ["python3", "-m", "pytest", "tests/", "-v", "--timeout=120"]
