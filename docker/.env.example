# APYROBO environment variables — copy to .env and fill in real values
# cp docker/.env.example docker/.env

# API authentication key — CHANGE THIS before deploying
APYROBO_API_KEY=changeme

# Log verbosity: DEBUG | INFO | WARNING | ERROR
APYROBO_LOG_LEVEL=INFO

# Redis URL for shared state persistence (leave empty to use in-process SQLite)
APYROBO_REDIS_URL=redis://redis:6379/0

# Path to SQLite audit database inside the container
APYROBO_AUDIT_DB=/app/data/audit/audit.db
